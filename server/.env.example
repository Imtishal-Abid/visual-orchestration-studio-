# ─────────────────────────────────────────────────────────
# Visual Orchestration Studio — environment configuration
# Copy this file to `.env` in the same folder and fill in
# your real key. Never commit the real `.env` file.
# ─────────────────────────────────────────────────────────

# Groq API key — powers two pipeline stages:
#   1. Prompt Payload Formulation: expands/cleans up the user's
#      raw prompt into a richer generation prompt using an LLM
#      (model: llama-3.3-70b-versatile).
#   2. Automated QA (Semantic Alignment Lens): a Groq vision
#      model (meta-llama/llama-4-scout-17b-16e-instruct) looks at
#      the generated image and rates how well it matches the
#      original prompt.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Port the Express server listens on
PORT=8787

# Image generation backend. Pollinations.ai requires no API key
# and is used as the default text-to-image engine (swap in
# DALL-E 3 / Stable Diffusion / your own provider by editing
# server.js -> generateImage()).
IMAGE_PROVIDER_BASE_URL=https://image.pollinations.ai/prompt
